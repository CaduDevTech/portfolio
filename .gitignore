```gitignore
# Dependências
node_modules/

# Build / arquivos compilados
dist/
out-tsc/
tmp/
.angular/
.ng/
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ambiente / variáveis sensíveis
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Arquivos de sistema operacional
.DS_Store
Thumbs.db

# IDEs / editores
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Cache / temporários
.cache/
*.tsbuildinfo

# Testes / reports
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# Firebase / deploy local, caso use
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Vercel / Netlify, caso use
.vercel/
.netlify/
```
